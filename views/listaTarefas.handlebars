<div class="container">
    <h1>Lista de Tarefas</h1>

    <a href="/tarefas/adicionar" class="btn">Adicionar Nova Tarefa</a>

    <ul>
        {{#each tarefas}}
        <li>
            {{descricao}} - {{#if concluida}}Concluída{{else}}Pendente{{/if}}
            <div>
                <a href="/tarefas/{{id}}/editar">Editar</a>
                <a href="/tarefas/{{id}}/excluir">Excluir</a>
            </div>
        </li>
        {{/each}}
    </ul>
</div>